{
  "functions": {
    "api/video/[videoId].js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/video/(.*)",
      "destination": "/api/video/[videoId]"
    },
    {
      "source": "/api/audio/(.*)",
      "destination": "/api/audio/[audioId]"
    },
    {
      "source": "/api/audio/preview/(.*)",
      "destination": "/api/audio/preview/[audioId]"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}